{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2025-12-26",
  "name": "skland-daily-attendance",
  "compatibility_flags": ["nodejs_als"],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "KV","id": "f7a5513dba7645fda4c9b1040305cd57"
    }
  ],
  "triggers": {
    "crons": ["30 0/2 * * *"]
  }
}
